{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Rating",
  "type": "object",
  "required": ["subject_id", "rater_identity_id", "task_id", "score"],
  "properties": {
    "subject_id": {"type": "string"},
    "rater_identity_id": {"type": "string"},
    "task_id": {"type": "string"},
    "score": {"type": "integer", "minimum": 0, "maximum": 10},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}

